# Google Maps JavaScript API key (Maps JavaScript API must be enabled)
# https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# VietMap API key for accurate geocoding and address autocomplete in Vietnam
# https://maps.vietmap.vn/
VITE_VIETMAP_API_KEY=5ccc4cd6f70448296dcc3ce29a3d34958dd4b86eef43fa46

# VietMap Tilemap API key for visual map tiles (if you have one, otherwise defaults to OpenFreeMap)
VITE_VIETMAP_TILEMAP_API_KEY=6ef81d02dd3377004ee1c34726cbb71c9393fe42f098e24e
